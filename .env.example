# ============================================================
# 必填配置 — 不填启动会报错
# ============================================================

# LLM 配置
OPENAI_API_KEY=your_api_key_here
LLM_MODEL=your_model_name_here
# OPENAI_BASE_URL 不填则使用 OpenAI 默认地址

# 百度地图配置
BAIDU_MAPS_API_KEY=your_baidu_maps_api_key_here
BAIDU_MAPS_JS_AK=your_baidu_maps_js_ak_here

# ============================================================
# 可选配置 — 以下都有默认值，不填也能跑
# ============================================================

# LLM 自定义 API 地址（用 DeepSeek / 智谱 等第三方时填写）
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# MySQL（默认: root@127.0.0.1:3306/bike_route_planner）
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DB=bike_route_planner

# Redis（默认: 127.0.0.1:6379）
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT（默认: change-me-in-production）
# JWT_SECRET_KEY=change-me-in-production

# 阿里云 OSS（可选，用于头像上传）
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=
# OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
